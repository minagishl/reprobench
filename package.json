{
  "name": "reprobench",
  "version": "0.1.0",
  "description": "Reproducible benchmark runner powered by Nix flakes",
  "keywords": [
    "benchmark",
    "cli",
    "nix",
    "reproducible"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/minagishl/reprobench"
  },
  "bin": {
    "reprobench": "./dist/cli.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "pnpm lint && pnpm fmt:check && pnpm test && pnpm build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "execa": "^9.0.0",
    "picocolors": "^1.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
